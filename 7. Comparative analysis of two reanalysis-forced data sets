def winsorize_series(s, q=(0.2, 99.8)):
    x = pd.to_numeric(s, errors="coerce").to_numpy(dtype=float)
    ok = np.isfinite(x)
    if ok.sum() < 10:
        return pd.Series(x, index=s.index)
    lo, hi = np.nanpercentile(x[ok], q)
    return pd.Series(np.clip(x, lo, hi), index=s.index)

def summary_stats(x):
    x = pd.to_numeric(x, errors="coerce").to_numpy(dtype=float)
    x = x[np.isfinite(x)]
    return {
        "n": int(len(x)),
        "mean": float(np.mean(x)),
        "median": float(np.median(x)),
        "p10": float(np.percentile(x, 10)),
        "p90": float(np.percentile(x, 90)),
    }

def smooth_hist_density(x, bins=60, xr=None):
    h, edges = np.histogram(x, bins=bins, range=xr, density=True)
    mids = 0.5 * (edges[:-1] + edges[1:])
    k = np.array([1, 4, 6, 4, 1], dtype=float)
    k = k / k.sum()
    hs = np.convolve(h, k, mode="same")
    return mids, hs

