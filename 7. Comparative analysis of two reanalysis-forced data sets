# ============================================================
# We use training-like robust fill:
# - numeric median within available rows
# - if still missing, overall median fallback
# No row dropping here, to keep same observation base.

def fill_features(X: pd.DataFrame):
    Xf = X.copy()
    med = {}
    for c in Xf.columns:
        v = pd.to_numeric(Xf[c], errors="coerce")
        m = float(np.nanmedian(v)) if np.isfinite(v).sum() > 0 else 0.0
        med[c] = m
        Xf[c] = v.fillna(m)
    return Xf, med

