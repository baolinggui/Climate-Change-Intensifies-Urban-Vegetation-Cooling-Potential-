def build_feature_frame(df_in: pd.DataFrame, source: str, feature_cols: list):
    """
    source = 'ERA5' or 'MERRA2'
    Returns a DataFrame with exactly the training feature columns.
    """
    X = pd.DataFrame(index=df_in.index)

    for c in feature_cols:
        if c in CLIM_VARS:
            if source == "ERA5":
                src_col = c
            elif source == "MERRA2":
                src_col = f"MERRA2hyb_{c}"
            else:
                raise ValueError("source must be 'ERA5' or 'MERRA2'")
        else:
            src_col = c

        if src_col not in df_in.columns:
            raise ValueError(f"❌ Required source column not found for {source}: {src_col}")

        X[c] = pd.to_numeric(df_in[src_col], errors="coerce")

    return X

