def bootstrap_ci_mean(values, B=300, alpha=0.05, seed=42):
    v = np.asarray(values, dtype=float)
    v = v[np.isfinite(v)]
    n = v.size
    if n <= 2:
        return (np.nan, np.nan)
    rng = np.random.RandomState(seed)
    means = np.empty(B, dtype=float)
    for b in range(B):
        idx = rng.randint(0, n, size=n)
        means[b] = np.nanmean(v[idx])
    lo = float(np.nanpercentile(means, 100*(alpha/2)))
    hi = float(np.nanpercentile(means, 100*(1-alpha/2)))
    return lo, hi

def define_city_summer(dataset):
    """City-specific summer = hottest TOPK_HOT_MONTHS baseline months by mean T2M."""
    d = dataset.copy()
    d = d.dropna(subset=[CITY, DATE, YEAR, MONTH, T2M, CE]).copy()
    base = d[(d[YEAR] >= BASELINE_YEARS[0]) & (d[YEAR] <= BASELINE_YEARS[1])].copy()

    cm = (
        base.groupby([CITY, MONTH], observed=True)[T2M]
            .mean()
            .reset_index()
            .sort_values([CITY, T2M], ascending=[True, False])
    )

    topm = (
        cm.groupby(CITY, observed=True)
          .head(TOPK_HOT_MONTHS)
          .groupby(CITY, observed=True)[MONTH]
          .apply(lambda x: sorted(x.astype(int).tolist()))
          .to_dict()
    )

    topm_set = {k: set(v) for k, v in topm.items()}
    d["is_summer"] = d.apply(lambda r: r[MONTH] in topm_set.get(r[CITY], set()), axis=1)
    d = d[d["is_summer"]].copy()
    return d

def add_active_and_highce(dataset_summer):
    """active from city baseline-summer Q60; HighCC from city summer P80 (all years summer)."""
    d = dataset_summer.copy()

    # active threshold from baseline summer
    base_s = d[(d[YEAR] >= BASELINE_YEARS[0]) & (d[YEAR] <= BASELINE_YEARS[1])].copy()
    q60 = (
        base_s.groupby(CITY, observed=True)[CE]
              .quantile(ACTIVE_Q)
              .rename("ce_q60_baseline")
              .reset_index()
    )
    d = d.merge(q60, on=CITY, how="left")
    d["active"] = (d[CE] > d["ce_q60_baseline"]).astype(np.int8)

    # HighCC threshold from all summer rows within each city
    q80 = (
        d.groupby(CITY, observed=True)[CE]
         .quantile(HIGH_Q_CITY)
         .rename("ce_q80_city")
         .reset_index()
    )
    d = d.merge(q80, on=CITY, how="left")
    d["HighCC"] = (d[CE] >= d["ce_q80_city"]).astype(np.int8)

    return d

def add_fixed_background_bins(dataset_summer):
    """Baseline-fixed T2M × VPD terciles for decomposition."""
    d = dataset_summer.copy()
    base_s = d[(d[YEAR] >= BASELINE_YEARS[0]) & (d[YEAR] <= BASELINE_YEARS[1])].copy()

    vpd_cuts = np.nanquantile(base_s[VPD].to_numpy(dtype=float), CLIM_Q)
    t2m_cuts = np.nanquantile(base_s[T2M].to_numpy(dtype=float), CLIM_Q)

    def _bin3(x, cuts):
        return np.where(x <= cuts[0], 1, np.where(x <= cuts[1], 2, 3))

    d["V_bin"] = _bin3(d[VPD].to_numpy(dtype=float), vpd_cuts).astype(np.int8)
    d["S_bin"] = _bin3(d[T2M].to_numpy(dtype=float), t2m_cuts).astype(np.int8)
    d["BG"] = ("S" + d["S_bin"].astype(str) + "_V" + d["V_bin"].astype(str)).astype("category")

    return d, vpd_cuts, t2m_cuts

def build_cityyear_panel(dataset_summer):
    agg_dict = {"active": "mean"}
    for c in use_feats:
        agg_dict[c] = "mean"

    df_cityyear = (
        dataset_summer[[CITY, YEAR, "active"] + use_feats]
        .dropna(subset=[CITY, YEAR, "active"])
        .groupby([CITY, YEAR], as_index=False, observed=True)
        .agg(agg_dict)
        .rename(columns={"active": "P_active"})
    )

    # period label
    df_cy = df_cityyear.copy()
    df_cy["period"] = np.nan
    for name, y0, y1 in PERIODS:
        m = (df_cy[YEAR] >= y0) & (df_cy[YEAR] <= y1)
        df_cy.loc[m, "period"] = name
    df_cy = df_cy.dropna(subset=["period"]).copy()
    df_cy["period"] = pd.Categorical(df_cy["period"], categories=[p[0] for p in PERIODS], ordered=True)

    # z-score predictors
    for c in use_feats:
        mu = df_cy[c].mean()
        sd = df_cy[c].std(ddof=0)
        df_cy[c + "_z"] = (df_cy[c] - mu) / (sd if pd.notna(sd) and sd > 0 else 1.0)

    return df_cy

def fit_twfe_period_interactions(df_cy, source_name):
    XZ = [c + "_z" for c in use_feats]
    formula = "P_active ~ (" + " + ".join(XZ) + ")*C(period) + C(city) + C(Year)"
    m = smf.ols(formula=formula, data=df_cy).fit(cov_type="HC3")

    coef = pd.DataFrame({
        "param": m.params.index,
        "beta": m.params.values,
        "se": m.bse.values,
        "p": m.pvalues.values
    })
    ci = m.conf_int()
    coef["ci_low"] = ci[0].values
    coef["ci_high"] = ci[1].values
    coef["source"] = source_name

    cov = m.cov_params()
    params = m.params

    def marg_effect(base, per):
        if per == REF_PERIOD:
            b = float(params.get(base, np.nan))
            v = float(cov.loc[base, base]) if (base in cov.index) else np.nan
        else:
            inter = f"{base}:C(period)[T.{per}]"
            b = float(params.get(base, 0.0) + params.get(inter, 0.0))
            if (base in cov.index) and (inter in cov.index):
                v = float(cov.loc[base, base] + cov.loc[inter, inter] + 2*cov.loc[base, inter])
            elif base in cov.index:
                v = float(cov.loc[base, base])
            else:
                v = np.nan
        se = np.sqrt(v) if pd.notna(v) and v >= 0 else np.nan
        return b, se

    rows = []
    for c in use_feats:
        base = c + "_z"
        for per, _, _ in PERIODS:
            b, se = marg_effect(base, per)
            rows.append({
                "feature": c,
                "period": per,
                "beta": b,
                "se": se,
                "ci_low": b - 1.96*se if pd.notna(se) else np.nan,
                "ci_high": b + 1.96*se if pd.notna(se) else np.nan,
                "source": source_name
            })

    meff = pd.DataFrame(rows)
    return coef, meff

def build_decomposition_tables(dataset_summer):
    # city-year-bg
    cy_n = (
        dataset_summer.groupby([CITY, YEAR], observed=True)
                     .size()
                     .rename("n_total")
                     .reset_index()
    )

    cybg = (
        dataset_summer.groupby([CITY, YEAR, "BG"], observed=True)
                     .agg(
                         n_bg=("active", "size"),
                         p_active_bg=("active", "mean"),
                         CE_median=(CE, "median"),
                         CE_trim=(CE, lambda x: float(np.nanmean(np.clip(x, np.nanpercentile(x, 10), np.nanpercentile(x, 90)))))
                     )
                     .reset_index()
    )

    cybg = cybg.merge(cy_n, on=[CITY, YEAR], how="left")
    cybg["p_bg"] = (cybg["n_bg"] / cybg["n_total"]).astype(float)
    cybg["contrib"] = (cybg["p_bg"] * cybg["p_active_bg"]).astype(float)

    # city-year overall
    cy_year = (
        cybg.groupby([CITY, YEAR], observed=True)
            .agg(
                P_active=("contrib", "sum"),
                CE_median=("CE_median", "mean"),
                CE_trim=("CE_trim", "mean")
            )
            .reset_index()
            .rename(columns={YEAR: "Year"})
    )

    return cybg, cy_year

def trend_table(cy_year, group_col, value_col, B=300):
    rows = []
    if group_col is None:
        for y in sorted(cy_year["Year"].unique()):
            sub = cy_year[cy_year["Year"] == y]
            vals = sub.groupby(CITY, observed=True)[value_col].mean().to_numpy()
            lo, hi = bootstrap_ci_mean(vals, B=B, alpha=CI_ALPHA, seed=42+int(y))
            rows.append(["Overall", y, float(np.nanmean(vals)), lo, hi, int(np.isfinite(vals).sum())])
    else:
        for g in cy_year[group_col].dropna().unique():
            g = str(g)
            gdf = cy_year[cy_year[group_col].astype(str) == g]
            for y in sorted(gdf["Year"].unique()):
                sub = gdf[gdf["Year"] == y]
                vals = sub.groupby(CITY, observed=True)[value_col].mean().to_numpy()
                lo, hi = bootstrap_ci_mean(vals, B=B, alpha=CI_ALPHA, seed=99 + hash(g) % 1000 + int(y))
                rows.append([g, y, float(np.nanmean(vals)), lo, hi, int(np.isfinite(vals).sum())])
    out = pd.DataFrame(rows, columns=["group","Year","mean","lo95","hi95","n_city"])
    return out

def grouped_contributions(contrib_wide):
    def vpd_level_from_bg(bg: str):
        try:
            return bg.split("_")[1]  # V1/V2/V3
        except Exception:
            return None

    bg_cols = list(contrib_wide.columns)
    VPD_FULL = {
        "V1": "Low atmospheric demand (low vapor pressure deficit)",
        "V2": "Moderate atmospheric demand (medium vapor pressure deficit)",
        "V3": "High atmospheric demand (high vapor pressure deficit)",
    }

    grouped = pd.DataFrame({"Year": contrib_wide.index.to_numpy()})
    for v_code, full_name in VPD_FULL.items():
        use_bgs = [b for b in bg_cols if vpd_level_from_bg(b) == v_code]
        grouped[full_name] = contrib_wide[use_bgs].sum(axis=1).to_numpy(dtype=float) if len(use_bgs) else 0.0
    return grouped

def city_divergence_table(dataset_summer):
    d = dataset_summer.copy()

    # city-specific VPD top-10% threshold using all summer rows
    vq = (
        d.groupby(CITY, observed=True)[VPD]
         .quantile(VPD_EXTREME_Q)
         .rename("VPD_q90_city")
         .reset_index()
    )
    d = d.merge(vq, on=CITY, how="left")
    d["is_vpd_tail"] = (d[VPD] >= d["VPD_q90_city"]).astype(np.int8)

    # assign periods
    d["period"] = np.nan
    for name, y0, y1 in PERIODS:
        m = (d[YEAR] >= y0) & (d[YEAR] <= y1)
        d.loc[m, "period"] = name
    d = d.dropna(subset=["period"]).copy()

    # city-period probabilities
    overall = (
        d.groupby([CITY, "period"], observed=True)["HighCC"]
         .mean()
         .rename("Pr_HighCC")
         .reset_index()
    )
    tail = (
        d[d["is_vpd_tail"] == 1]
         .groupby([CITY, "period"], observed=True)["HighCC"]
         .mean()
         .rename("Pr_HighCC_tail")
         .reset_index()
    )

    wide_o = overall.pivot(index=CITY, columns="period", values="Pr_HighCC")
    wide_t = tail.pivot(index=CITY, columns="period", values="Pr_HighCC_tail")

    out = pd.DataFrame(index=wide_o.index.union(wide_t.index))
    out["Pr_A"] = wide_o.get("A_2002_2006")
    out["Pr_B"] = wide_o.get("B_2019_2025")
    out["Pr_A_tail"] = wide_t.get("A_2002_2006")
    out["Pr_B_tail"] = wide_t.get("B_2019_2025")

    out["dPr"] = out["Pr_B"] - out["Pr_A"]
    out["dPr_tail"] = out["Pr_B_tail"] - out["Pr_A_tail"]
    out = out.reset_index().rename(columns={"index": CITY})

    def quadrant(x, y):
        if pd.isna(x) or pd.isna(y):
            return "missing"
        if x >= 0 and y >= 0:
            return "gain_both"
        if x >= 0 and y < 0:
            return "gain_avg_loss_extreme"
        if x < 0 and y < 0:
            return "loss_both"
        return "loss_avg_gain_extreme"

    out["quadrant"] = [quadrant(x, y) for x, y in zip(out["dPr"], out["dPr_tail"])]
    return out

def run_core(dataset, source_name):
    ds = define_city_summer(dataset)
    ds = add_active_and_highce(ds)
    ds, vpd_cuts, t2m_cuts = add_fixed_background_bins(ds)

    # Fig4
    df_cy = build_cityyear_panel(ds)
    coef_all, meff = fit_twfe_period_interactions(df_cy, source_name)

    # Fig5
    cybg, cy_year = build_decomposition_tables(ds)
    trend_all = trend_table(cy_year, None, "P_active", B=BOOT_N)

    contrib = (
        cybg.groupby(["Year","BG"], observed=True)["contrib"].mean().reset_index()
            .pivot(index="Year", columns="BG", values="contrib")
            .fillna(0.0)
    )
    grouped = grouped_contributions(contrib)

    # Fig6
    city_div = city_divergence_table(ds)

    return {
        "summer": ds,
        "cityyear": df_cy,
        "coef_all": coef_all,
        "meff": meff,
        "trend_all": trend_all,
        "contrib_wide": contrib,
        "grouped_contrib": grouped,
        "city_div": city_div,
        "vpd_cuts": vpd_cuts,
        "t2m_cuts": t2m_cuts
    }

