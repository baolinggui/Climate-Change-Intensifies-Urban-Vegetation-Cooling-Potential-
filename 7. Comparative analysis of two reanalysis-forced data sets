# This follows your earlier logic of computing cooling_strength_pred
# and cooling_efficiency from the trained final model. :contentReference[oaicite:2]{index=2}
# ============================================================
def compute_ce_for_source(df_in, X_full, source_name, evi_eps=0.02):
    X_obs = X_full.copy()
    X_cf  = X_full.copy()

    if "EVI" not in X_cf.columns:
        raise ValueError("❌ EVI must be included in feature_cols for counterfactual prediction.")

    X_cf["EVI"] = 0.0

    pred_obs = predict_model(final, X_obs)
    pred_cf  = predict_model(final, X_cf)

    out = pd.DataFrame(index=df_in.index)
    out[f"LST_pred_{source_name}"] = pred_obs
    out[f"LST_pred_noEVI_{source_name}"] = pred_cf
    out[f"cooling_strength_pred_{source_name}"] = pred_cf - pred_obs

    evi_safe = np.maximum(df_in["EVI"].to_numpy(dtype=float), evi_eps)
    out[f"cooling_efficiency_{source_name}"] = out[f"cooling_strength_pred_{source_name}"].to_numpy(dtype=float) / evi_safe

    return out

ce_era = compute_ce_for_source(df, X_era_f, "ERA5", evi_eps=EVI_EPS)
