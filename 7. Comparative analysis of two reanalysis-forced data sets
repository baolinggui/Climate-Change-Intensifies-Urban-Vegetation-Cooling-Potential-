def prepare_dataset(dataset):
    df0 = dataset.copy()
    need = [CITY, DATE, Y] + FEATURES + [YEAR, MONTH]
    miss = [c for c in need if c not in df0.columns]
    if miss:
        raise ValueError(f"dataset missing columns: {miss}")

    df0 = df0.dropna(subset=[CITY, DATE, Y]).copy()

    # optional city-level cap, exactly in the spirit of your original script
    if ENABLE_CITY_SAMPLING:
        rng = np.random.default_rng(RNG_SEED)
        parts = []
        for _, sub in df0.groupby(CITY, observed=True):
            if len(sub) > MAX_ROWS_PER_CITY:
                idx = rng.choice(sub.index.to_numpy(), size=MAX_ROWS_PER_CITY, replace=False)
                parts.append(df0.loc[idx].copy())
            else:
                parts.append(sub.copy())
        df0 = pd.concat(parts, axis=0, ignore_index=True)

    # define city-specific summer by baseline hottest months using T2M_C
    base = df0[(df0[YEAR] >= BASELINE_YEARS[0]) & (df0[YEAR] <= BASELINE_YEARS[1])].copy()
    mm = (
        base.groupby([CITY, MONTH], observed=True)["T2M_C"]
            .median()
            .reset_index()
            .sort_values([CITY, "T2M_C"], ascending=[True, False])
    )
    mm["rk"] = mm.groupby(CITY, observed=True).cumcount() + 1
    hot = mm[mm["rk"] <= TOPK_HOT_MONTHS][[CITY, MONTH]].copy()
    hot["is_summer"] = 1

    df0 = df0.merge(hot, on=[CITY, MONTH], how="left")
    df0["is_summer"] = df0["is_summer"].fillna(0).astype(np.int8)
    df = df0[df0["is_summer"] == 1].copy()

    # background bins from summer T2M × VPD terciles
    tb = df["T2M_C"].to_numpy(dtype=float)
    vb = df["VPD_kPa"].to_numpy(dtype=float)
    t1, t2 = np.nanpercentile(tb[np.isfinite(tb)], [33.333, 66.666])
    v1, v2 = np.nanpercentile(vb[np.isfinite(vb)], [33.333, 66.666])

    def t_bin(x):
        if x <= t1: return "T1"
        if x <= t2: return "T2"
        return "T3"

    def v_bin(x):
        if x <= v1: return "V1"
        if x <= v2: return "V2"
        return "V3"

    df["BG"] = [f"{t_bin(t)}_{v_bin(v)}" for t, v in zip(df["T2M_C"].to_numpy(), df["VPD_kPa"].to_numpy())]
    return df.reset_index(drop=True)

def build_curve_city_bootstrap(df_bg, xcol, ycol="cooling_efficiency",
                               n_bins=25, min_city_per_bin=15, boot_n=200, rng_seed=42):
    d = df_bg[[CITY, xcol, ycol]].copy().replace([np.inf, -np.inf], np.nan).dropna()
    if len(d) < 500:
        return None, None

    # qcut to bins
    d["bin"] = pd.qcut(d[xcol], q=n_bins, duplicates="drop")
    mids = d.groupby("bin", observed=True)[xcol].median().to_numpy()

    # city-bin medians
    city_bin = (
        d.groupby([CITY, "bin"], observed=True)[ycol]
         .median()
         .reset_index()
    )

    # overall median per bin
    grp = city_bin.groupby("bin", observed=True)[ycol]
    value = grp.median()
    n_city = grp.count()

    piv = city_bin.pivot_table(index="bin", columns=CITY, values=ycol, aggfunc="median")
    bins = np.arange(len(piv.index))
    if len(bins) < 5:
        return None, None

    cities = piv.columns.astype(str).to_numpy()
    arr = piv.to_numpy(dtype=float)

    rng = np.random.default_rng(rng_seed)
    boots = np.full((boot_n, len(bins)), np.nan, dtype=float)
    for b in range(boot_n):
        samp = rng.integers(0, len(cities), size=len(cities))
        boots[b, :] = np.nanmedian(arr[:, samp], axis=1)

    lo = np.nanpercentile(boots, 2.5, axis=0)
    hi = np.nanpercentile(boots, 97.5, axis=0)

    out = pd.DataFrame({
        "bin_id": bins,
        "x_mid": np.array([mids[i] if i < len(mids) else np.nan for i in bins], dtype=float),
        "value": value.to_numpy(dtype=float),
        "lo": lo,
        "hi": hi,
        "n_city": n_city.to_numpy(dtype=float)
    })
    out = out[out["n_city"] >= min_city_per_bin].copy().sort_values("x_mid").reset_index(drop=True)
    return out, city_bin

def run_curves_threevars(dataset, source_name):
    df = prepare_dataset(dataset)
    response = {}
    for bg in sorted(df["BG"].unique()):
        sub_bg = df[df["BG"] == bg].copy()
        for xcol in ["EVI", "VPD_kPa", "SSRD_MJm2"]:
            curve_df, _ = build_curve_city_bootstrap(
                sub_bg, xcol=xcol, ycol="cooling_efficiency",
                n_bins=N_BINS, min_city_per_bin=MIN_CITY_PER_BIN,
                boot_n=BOOT_N, rng_seed=RNG_SEED
            )
            if curve_df is not None:
                curve_df["BG"] = bg
                curve_df["xcol"] = xcol
                curve_df["source"] = source_name
                response[(bg, xcol)] = curve_df
    return response

def fit_importance(dataset, source_name, seed=42):
    df = dataset[[CITY, DATE, Y] + FEATURES].copy()
    df = df.replace([np.inf, -np.inf], np.nan).dropna().reset_index(drop=True)

    # light sample
    if 0 < IMP_SAMPLE_FRAC < 1:
        rng = np.random.default_rng(seed)
        n_take = max(1000, int(len(df) * IMP_SAMPLE_FRAC))
        n_take = min(n_take, len(df))
        idx = rng.choice(df.index.to_numpy(), size=n_take, replace=False)
        df = df.loc[idx].copy().reset_index(drop=True)

    uniq_dates = np.array(sorted(pd.to_datetime(df[DATE]).dt.normalize().unique()))
    if len(uniq_dates) < 5:
        raise ValueError(f"Too few unique dates for {source_name}: {len(uniq_dates)}")

    cut_idx = int(len(uniq_dates) * 0.8)
    cut_idx = min(max(cut_idx, 1), len(uniq_dates) - 1)
    cut_date = uniq_dates[cut_idx]

    train_mask = pd.to_datetime(df[DATE]).dt.normalize() < cut_date
    test_mask  = ~train_mask

    X_train = df.loc[train_mask, FEATURES].to_numpy(dtype=np.float32)
    y_train = df.loc[train_mask, Y].to_numpy(dtype=np.float32)
    X_test  = df.loc[test_mask, FEATURES].to_numpy(dtype=np.float32)
    y_test  = df.loc[test_mask, Y].to_numpy(dtype=np.float32)

    if len(X_train) == 0 or len(X_test) == 0:
        raise ValueError(
            f"{source_name}: empty train/test split. "
            f"train={len(X_train)}, test={len(X_test)}"
        )

    model = xgb.XGBRegressor(random_state=seed, **XGB_PARAMS)
    model.fit(X_train, y_train)
    pred = model.predict(X_test)

    # ---- compatibility-safe metrics ----
    mse = mean_squared_error(y_test, pred)
    rmse = float(np.sqrt(mse))
    mae = float(mean_absolute_error(y_test, pred))
    r2 = float(r2_score(y_test, pred))

    booster = model.get_booster()
    score = booster.get_score(importance_type="gain")
    imp = pd.DataFrame({
        "feature": FEATURES,
        "gain": [score.get(f"f{i}", 0.0) for i in range(len(FEATURES))]
    })

    gain_sum = imp["gain"].sum()
    if gain_sum > 0:
        imp["gain_norm"] = imp["gain"] / gain_sum
    else:
        imp["gain_norm"] = 0.0

    imp["source"] = source_name

    metrics = {"rmse": rmse, "mae": mae, "r2": r2}
    return imp, metrics

def run_threshold(dataset, source_name):
    df = dataset.copy()
    need_cols = [CITY, DATE, EVI, CE, VPD, SSRD, T2M, YEAR, MONTH]
    df = df[need_cols].dropna().copy()
    df[DATE] = pd.to_datetime(df[DATE], errors="coerce")

    # per-city cap
    rng = np.random.default_rng(RNG_SEED)
    parts = []
    for _, sub in df.groupby(CITY, observed=True):
        if len(sub) > PER_CITY_CAP:
            idx = rng.choice(sub.index.to_numpy(), size=PER_CITY_CAP, replace=False)
            parts.append(df.loc[idx].copy())
        else:
            parts.append(sub.copy())
    df = pd.concat(parts, axis=0, ignore_index=True)

    # city-specific summer months
    base = df[(df[YEAR] >= BASELINE_YEARS[0]) & (df[YEAR] <= BASELINE_YEARS[1])].copy()
    mm = (
        base.groupby([CITY, MONTH], observed=True)[T2M]
            .median()
            .reset_index()
            .sort_values([CITY, T2M], ascending=[True, False])
    )
    mm["rk"] = mm.groupby(CITY, observed=True).cumcount() + 1
    hot = mm[mm["rk"] <= TOPK_HOT_MONTHS][[CITY, MONTH]].copy()
    hot["is_summer"] = 1

    df = df.merge(hot, on=[CITY, MONTH], how="left")
    df["is_summer"] = df["is_summer"].fillna(0).astype(np.int8)
    summer = df[df["is_summer"] == 1].copy()

    base_s = summer[(summer[YEAR] >= BASELINE_YEARS[0]) & (summer[YEAR] <= BASELINE_YEARS[1])].copy()
    thr = base_s.groupby(CITY, observed=True)[CE].quantile(CE_Q_ACTIVE).rename("CE_thr").reset_index()
    summer = summer.merge(thr, on=CITY, how="left")
    summer["active"] = (summer[CE] > summer["CE_thr"]).astype(np.int8)

    # grid bins from summer distribution
    summer["b_vpd"]  = pd.qcut(summer[VPD], q=N_BINS_VPD, duplicates="drop", labels=False)
    summer["b_ssrd"] = pd.qcut(summer[SSRD], q=N_BINS_SSRD, duplicates="drop", labels=False)
    summer["evi_bin"] = pd.qcut(summer[EVI], q=N_BINS_EVI, duplicates="drop", labels=False)
    summer = summer.dropna(subset=["b_vpd","b_ssrd","evi_bin"]).copy()

    # mids
    vpd_mids = summer.groupby("b_vpd", observed=True)[VPD].median().sort_index().to_numpy()
    ssrd_mids = summer.groupby("b_ssrd", observed=True)[SSRD].median().sort_index().to_numpy()

    def compute_threshold_grid(sub_df, p0=0.50):
        out_rows = []
        for (bv, bs), sub in sub_df.groupby(["b_vpd", "b_ssrd"], observed=True):
            n_city = sub[CITY].nunique()
            if n_city < MIN_CITY_PER_CELL:
                continue

            prof = (
                sub.groupby("evi_bin", observed=True)
                   .agg(
                       EVI_mid=(EVI, "median"),
                       p_active=("active", "mean"),
                       n=("active", "size")
                   )
                   .reset_index()
                   .sort_values("EVI_mid")
            )
            prof = prof[prof["n"] >= MIN_SAMPLES_PER_EVI_BIN].copy()
            if len(prof) < 3:
                continue

            thr = np.nan
            hit = np.where(prof["p_active"].to_numpy(dtype=float) >= p0)[0]
            if len(hit):
                j = hit[0]
                if j == 0:
                    thr = float(prof.iloc[j]["EVI_mid"])
                else:
                    x0, y0 = float(prof.iloc[j-1]["EVI_mid"]), float(prof.iloc[j-1]["p_active"])
                    x1, y1 = float(prof.iloc[j]["EVI_mid"]),  float(prof.iloc[j]["p_active"])
                    thr = x1 if y1 == y0 else x0 + (p0 - y0) * (x1 - x0) / (y1 - y0)

            out_rows.append({
                "b_vpd": int(bv),
                "b_ssrd": int(bs),
                "VPD_mid": float(vpd_mids[int(bv)]),
                "SSRD_mid": float(ssrd_mids[int(bs)]),
                "evi_thr": thr,
                "n_city": int(n_city),
                "n_rows": int(len(sub)),
                "source": source_name
            })
        return pd.DataFrame(out_rows)

    grid = compute_threshold_grid(summer, p0=P0)
    return grid

