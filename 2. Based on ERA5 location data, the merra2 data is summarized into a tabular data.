# ============================================================
# 0) PATHS
# ============================================================
MATCHED_CSV = "/content/drive/MyDrive/Second_research/MERRA/processed/ERA5_MERRA2_matched_raw_samples.csv"
ERA5_PARQUET = "/content/drive/MyDrive/Second_research/derived_datasets/GlobalUrbanCooling_dataset_v2.parquet"

