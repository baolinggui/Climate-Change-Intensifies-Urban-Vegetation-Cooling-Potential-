# ============================================================
# 1) CONFIG
# ============================================================
# high-consistency variables -> robust linear
LINEAR_VARS = ["T2M_C", "TD_C", "VPD_kPa", "SSRD_MJm2", "STL1_C"]

# weaker / more nonlinear variables -> tree model
TREE_VARS = ["WIND10M_MS", "TP_mm", "SWVL1_m3m3"]

# train sample sizes
MAX_TRAIN_LINEAR = 1_200_000   # enough, still manageable
MAX_TRAIN_TREE   =   500_000   # keep training fast
VALID_FRAC       = 0.15
RANDOM_SEED      = 42

# clip outputs to physically reasonable bounds
PHYSICAL_BOUNDS = {
    "VPD_kPa":     (0.0, None),
    "WIND10M_MS":  (0.0, None),
    "SSRD_MJm2":   (0.0, None),
    "TP_mm":       (0.0, None),
    "SWVL1_m3m3":  (0.0, 1.0),
}

# predictor sets for nonlinear variables
TREE_FEATURES = {
    "WIND10M_MS": ["WIND10M_MS_ERA5", "T2M_C_ERA5", "TD_C_ERA5", "VPD_kPa_ERA5", "SSRD_MJm2_ERA5"],
    "TP_mm":      ["TP_mm_ERA5", "T2M_C_ERA5", "TD_C_ERA5", "VPD_kPa_ERA5", "SSRD_MJm2_ERA5"],
    "SWVL1_m3m3": ["SWVL1_m3m3_ERA5", "TP_mm_ERA5", "T2M_C_ERA5", "VPD_kPa_ERA5", "STL1_C_ERA5"]
}

# linear variables only use their own ERA5 counterpart
def linear_feature(var):
    return [f"{var}_ERA5"]

# ============================================================
# 2) HELPERS
# ============================================================
def safe_rmse(y_true, y_pred):
    return float(np.sqrt(mean_squared_error(y_true, y_pred)))

def clip_physical(arr, varname):
    if varname not in PHYSICAL_BOUNDS:
        return arr
    lo, hi = PHYSICAL_BOUNDS[varname]
    arr = np.asarray(arr, dtype=float)
    if lo is not None:
        arr = np.maximum(arr, lo)
    if hi is not None:
        arr = np.minimum(arr, hi)
    return arr

def summarize_model(y_true, y_pred):
    diff = np.asarray(y_pred) - np.asarray(y_true)
    return {
        "r2": float(r2_score(y_true, y_pred)),
        "mae": float(mean_absolute_error(y_true, y_pred)),
        "rmse": safe_rmse(y_true, y_pred),
        "bias": float(np.mean(diff)),
        "diff_p05": float(np.quantile(diff, 0.05)),
        "diff_p50": float(np.quantile(diff, 0.50)),
        "diff_p95": float(np.quantile(diff, 0.95)),
    }

def train_linear_model(train_df, valid_df, var):
    xcols = linear_feature(var)
    ycol = f"{var}_MERRA2"

    Xtr = train_df[xcols].to_numpy(dtype=float)
    ytr = train_df[ycol].to_numpy(dtype=float)

    Xva = valid_df[xcols].to_numpy(dtype=float)
    yva = valid_df[ycol].to_numpy(dtype=float)

    model = HuberRegressor()
    model.fit(Xtr, ytr)

    pred_tr = clip_physical(model.predict(Xtr), var)
    pred_va = clip_physical(model.predict(Xva), var)

    row = {
        "variable": var,
        "model_type": "HuberRegressor",
        "feature_cols": "|".join(xcols),
        "n_train": len(train_df),
        "n_valid": len(valid_df),
        "coef_0": float(model.coef_[0]) if len(model.coef_) > 0 else np.nan,
        "intercept": float(model.intercept_),
    }
    row.update({f"train_{k}": v for k, v in summarize_model(ytr, pred_tr).items()})
    row.update({f"valid_{k}": v for k, v in summarize_model(yva, pred_va).items()})

    valid_out = valid_df[["city", "date", ycol] + xcols].copy()
    valid_out["variable"] = var
    valid_out["pred_MERRA2"] = pred_va
    valid_out["true_MERRA2"] = yva

    return model, row, valid_out

def train_tree_model(train_df, valid_df, var):
    xcols = TREE_FEATURES[var]
    ycol = f"{var}_MERRA2"

    Xtr = train_df[xcols].to_numpy(dtype=float)
    ytr = train_df[ycol].to_numpy(dtype=float)

    Xva = valid_df[xcols].to_numpy(dtype=float)
    yva = valid_df[ycol].to_numpy(dtype=float)

    model = HistGradientBoostingRegressor(
        loss="squared_error",
        learning_rate=0.05,
        max_iter=300,
        max_leaf_nodes=31,
        min_samples_leaf=100,
        l2_regularization=0.1,
        random_state=RANDOM_SEED
    )
    model.fit(Xtr, ytr)

    pred_tr = clip_physical(model.predict(Xtr), var)
    pred_va = clip_physical(model.predict(Xva), var)

    row = {
        "variable": var,
        "model_type": "HistGradientBoostingRegressor",
        "feature_cols": "|".join(xcols),
        "n_train": len(train_df),
        "n_valid": len(valid_df),
        "coef_0": np.nan,
        "intercept": np.nan,
    }
    row.update({f"train_{k}": v for k, v in summarize_model(ytr, pred_tr).items()})
    row.update({f"valid_{k}": v for k, v in summarize_model(yva, pred_va).items()})

    valid_out = valid_df[["city", "date", ycol] + xcols].copy()
    valid_out["variable"] = var
    valid_out["pred_MERRA2"] = pred_va
    valid_out["true_MERRA2"] = yva

    return model, row, valid_out

def build_training_subset(df, xcols, ycol, max_n):
    sub = df[xcols + [ycol]].replace([np.inf, -np.inf], np.nan).dropna().copy()
    if "city" in df.columns:
        keep_cols = list(dict.fromkeys(["city", "date"] + xcols + [ycol]))
        sub = df[keep_cols].replace([np.inf, -np.inf], np.nan).dropna().copy()
    if len(sub) > max_n:
        sub = sub.sample(max_n, random_state=RANDOM_SEED)
    return sub

