# helper: map training feature names back to parquet feature names
def map_train_feature_to_parquet(colname: str) -> str:
    # training table uses *_ERA5, full parquet uses raw names
    if colname.endswith("_ERA5"):
        return colname[:-5]   # remove "_ERA5"
    return colname

prediction_report = []

for var, bundle in fitted_models.items():
    train_xcols = bundle["feature_cols"]   # e.g. ['T2M_C_ERA5'] or mixed *_ERA5
    model = bundle["model"]

    parquet_xcols = [map_train_feature_to_parquet(c) for c in train_xcols]

    missing = [c for c in parquet_xcols if c not in era.columns]
    if len(missing) > 0:
        raise ValueError(
            f"Missing feature columns for {var} in full ERA parquet.\n"
            f"Training cols: {train_xcols}\n"
            f"Mapped parquet cols: {parquet_xcols}\n"
            f"Missing: {missing}"
        )

    X = era[parquet_xcols].replace([np.inf, -np.inf], np.nan).copy()

    pred = np.full(len(era), np.nan, dtype=np.float32)
    mask = X.notna().all(axis=1).to_numpy()

    if mask.sum() == 0:
        print(f"[WARN] no valid rows for {var}")
        hybrid_add["MERRA2hyb_" + var] = pred
        prediction_report.append({
            "variable": var,
            "n_total": len(era),
            "n_valid_rows": 0,
            "coverage": 0.0
        })
        continue

    Xv = X.loc[mask, parquet_xcols].to_numpy(dtype=float)

    yhat = model.predict(Xv)
    yhat = clip_physical(yhat, var).astype(np.float32)

    pred[mask] = yhat
    hybrid_add["MERRA2hyb_" + var] = pred

    prediction_report.append({
        "variable": var,
        "n_total": len(era),
        "n_valid_rows": int(mask.sum()),
        "coverage": float(mask.mean())
    })

    print(
        f"✅ predicted {var}: "
        f"valid rows = {mask.sum():,} / {len(era):,} "
        f"({mask.mean():.4%})"
    )

# optional: save prediction coverage report
